<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Whitelet - The Light-Themed Platform</title>
    <style>
        /* Global Styles */
        :root {
            --primary-blue: #0078D7;
            --dark-blue: #005BB5;
            --light-blue: #E6F2FF;
            --white: #FFFFFF;
            --light-gray: #F5F5F5;
            --medium-gray: #E0E0E0;
            --dark-gray: #333333;
            --success: #28A745;
            --warning: #FFC107;
            --danger: #DC3545;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
            background-color: var(--white);
            color: var(--dark-gray);
            line-height: 1.6;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        header {
            text-align: center;
            margin-bottom: 2rem;
        }

        .logo-white {
            color: var(--dark-gray);
            font-weight: bold;
        }

        .logo-blue {
            color: var(--primary-blue);
            font-weight: bold;
        }

        h1 {
            font-size: 3rem;
            margin-bottom: 0;
        }

        .tagline {
            color: var(--dark-gray);
            font-style: italic;
            margin-top: -0.5rem;
        }

        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-weight: bold;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
        }

        .btn-primary {
            background-color: var(--primary-blue);
            color: var(--white);
        }

        .btn-primary:hover {
            background-color: var(--dark-blue);
        }

        .btn-secondary {
            background-color: var(--light-gray);
            color: var(--dark-gray);
        }

        .btn-secondary:hover {
            background-color: var(--medium-gray);
        }

        .btn-small {
            padding: 5px 10px;
            font-size: 0.8rem;
        }

        /* Dashboard Styles */
        .dashboard-container {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 20px;
            background-color: var(--white);
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
        }

        .navbar-brand {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .market-title {
            font-weight: bold;
            color: var(--primary-blue);
        }

        .user-info {
            display: flex;
            gap: 20px;
        }

        .balance {
            color: var(--primary-blue);
            font-weight: bold;
        }

        .bottom-nav {
            display: flex;
            justify-content: space-around;
            padding: 15px;
            background-color: var(--white);
            box-shadow: 0 -2px 5px rgba(0, 0, 0, 0.1);
        }

        .nav-link {
            text-decoration: none;
            color: var(--dark-gray);
            font-weight: bold;
        }

        .nav-link:hover {
            color: var(--primary-blue);
        }

        /* Market Styles */
        .market-container, .packs-container, .blooks-container, .auction-container, .trade-container {
            padding: 20px;
            flex: 1;
        }

        .market-tabs, .pack-categories, .trade-tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            overflow-x: auto;
            padding-bottom: 10px;
        }

        .tab-btn, .pack-category-btn {
            padding: 8px 16px;
            border: none;
            border-radius: 20px;
            background-color: var(--light-gray);
            cursor: pointer;
            white-space: nowrap;
        }

        .tab-btn.active, .pack-category-btn.active {
            background-color: var(--primary-blue);
            color: white;
        }

        .items-grid, .packs-grid, .blooks-grid, .auctions-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 20px;
            margin: 20px 0;
        }

        .item-card, .pack-card, .blook-card, .auction-card {
            border: 1px solid var(--medium-gray);
            border-radius: 8px;
            padding: 15px;
            text-align: center;
            transition: transform 0.3s ease;
        }

        .item-card:hover, .pack-card:hover, .blook-card:hover, .auction-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        }

        .item-card img, .pack-card img, .blook-card img, .auction-blook img {
            max-width: 100%;
            height: 100px;
            object-fit: contain;
            margin-bottom: 10px;
        }

        .item-price, .pack-price {
            color: var(--primary-blue);
            font-weight: bold;
            margin: 10px 0;
        }

        .item-rarity, .pack-odds, .blook-rarity {
            font-size: 0.8rem;
            color: var(--dark-gray);
            margin-bottom: 10px;
        }

        /* Pack Specific Styles */
        .pack-card img {
            height: 150px;
        }

        /* Blook Specific Styles */
        .blook-actions {
            display: flex;
            gap: 5px;
            justify-content: center;
        }

        /* Rarity Styles */
        .uncommon {
            border-color: #28A745;
        }

        .rare {
            border-color: #17A2B8;
        }

        .epic {
            border-color: #6F42C1;
        }

        .legendary {
            border-color: #FD7E14;
        }

        .chroma {
            border: 2px solid;
            border-image: linear-gradient(45deg, #FF0000, #FF7F00, #FFFF00, #00FF00, #0000FF, #4B0082, #9400D3) 1;
        }

        .mystical {
            border: 2px solid;
            border-image: linear-gradient(45deg, #FFD700, #C0C0C0, #CD7F32) 1;
        }

        .rarity-badge {
            display: inline-block;
            padding: 3px 8px;
            border-radius: 4px;
            font-size: 0.8rem;
            font-weight: bold;
            margin-left: 10px;
        }

        .rarity-uncommon {
            background-color: #28A745;
            color: white;
        }

        .rarity-rare {
            background-color: #17A2B8;
            color: white;
        }

        .rarity-epic {
            background-color: #6F42C1;
            color: white;
        }

        .rarity-legendary {
            background-color: #FD7E14;
            color: white;
        }

        .rarity-chroma {
            background: linear-gradient(45deg, #FF0000, #FF7F00, #FFFF00, #00FF00, #0000FF, #4B0082, #9400D3);
            color: white;
        }

        .rarity-mystical {
            background: linear-gradient(45deg, #FFD700, #C0C0C0, #CD7F32);
            color: black;
        }

        /* Auction Specific Styles */
        .auction-card {
            display: flex;
            text-align: left;
        }

        .auction-blook {
            flex: 1;
        }

        .auction-info {
            flex: 2;
            padding-left: 15px;
        }

        .current-bid, .time-left, .seller {
            margin: 5px 0;
        }

        .bid-form {
            display: flex;
            gap: 5px;
            margin-top: 10px;
        }

        .bid-form input {
            flex: 1;
            padding: 5px;
            border: 1px solid var(--medium-gray);
            border-radius: 4px;
        }

        /* Trade Specific Styles */
        .trade-card {
            border: 1px solid var(--medium-gray);
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 15px;
        }

        .trade-parties {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 15px;
        }

        .trade-user {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .trade-user img {
            width: 30px;
            height: 30px;
            border-radius: 50%;
        }

        .trade-arrow {
            font-size: 1.5rem;
            padding: 0 20px;
        }

        .trade-items {
            display: flex;
            justify-content: space-between;
            margin-bottom: 15px;
        }

        .trade-offer, .trade-receive {
            flex: 1;
        }

        .trade-blook {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 10px;
        }

        .trade-blook img {
            width: 40px;
            height: 40px;
        }

        .trade-actions {
            display: flex;
            gap: 10px;
            justify-content: flex-end;
        }

        /* Admin Styles */
        .admin-container {
            display: flex;
            flex: 1;
        }

        .admin-sidebar {
            width: 200px;
            background-color: var(--light-gray);
            padding: 20px;
        }

        .admin-link {
            display: block;
            padding: 10px;
            margin-bottom: 5px;
            text-decoration: none;
            color: var(--dark-gray);
            border-radius: 4px;
        }

        .admin-link:hover, .admin-link.active {
            background-color: var(--primary-blue);
            color: white;
        }

        .admin-content {
            flex: 1;
            padding: 20px;
        }

        .admin-table {
            width: 100%;
            border-collapse: collapse;
        }

        .admin-table th, .admin-table td {
            padding: 10px;
            border: 1px solid var(--medium-gray);
            text-align: left;
        }

        .admin-table th {
            background-color: var(--light-gray);
        }

        .admin-blook-img {
            width: 50px;
            height: 50px;
            object-fit: contain;
        }

        /* Modal Styles */
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
        }

        .modal-content {
            background-color: var(--white);
            margin: 10% auto;
            padding: 20px;
            border-radius: 8px;
            max-width: 500px;
            position: relative;
        }

        .close-modal {
            position: absolute;
            right: 15px;
            top: 10px;
            font-size: 24px;
            cursor: pointer;
        }

        .form-group {
            margin-bottom: 15px;
        }

        .form-group label {
            display: block;
            margin-bottom: 5px;
            font-weight: bold;
        }

        .form-group input, .form-group select {
            width: 100%;
            padding: 8px;
            border: 1px solid var(--medium-gray);
            border-radius: 4px;
        }

        /* Page-specific styles to show/hide content */
        .page {
            display: none;
        }

        .page.active {
            display: block;
        }
    </style>
</head>
<body>
    <!-- Main Container -->
    <div id="app">
        <!-- Login Page -->
        <div id="login-page" class="page active">
            <div class="container">
                <header>
                    <h1><span class="logo-white">WHITE</span><span class="logo-blue">LET</span></h1>
                    <p class="tagline">The Light-Themed Platform</p>
                </header>

                <div class="login-box">
                    <h2>Welcome to Whitelet</h2>
                    <form id="loginForm">
                        <div class="form-group">
                            <label for="username">Username</label>
                            <input type="text" id="username" required>
                        </div>
                        <div class="form-group">
                            <label for="password">Password</label>
                            <input type="password" id="password" required>
                        </div>
                        <div class="form-actions">
                            <button type="submit" class="btn btn-primary">Login</button>
                            <button type="button" id="registerBtn" class="btn btn-secondary">Register</button>
                        </div>
                    </form>
                    <div class="links">
                        <a href="#" onclick="showPage('stats-page')">View Stats</a>
                    </div>
                </div>

                <footer>
                    <p>Owner: Augustine2025 | Admin: nightfall</p>
                    <p>All accounts are reset from previous versions</p>
                </footer>
            </div>
        </div>

        <!-- Dashboard Page -->
        <div id="dashboard-page" class="page">
            <div class="dashboard-container">
                <nav class="navbar">
                    <div class="navbar-brand">
                        <span class="logo-white">WHITE</span><span class="logo-blue">LET</span>
                    </div>
                    <div class="user-info">
                        <span>Welcome, <span id="usernameDisplay">User123</span></span>
                        <span class="balance">Balance: <span id="userBalance">1,250</span></span>
                    </div>
                </nav>

                <div class="market-container">
                    <h2>Quick Actions</h2>
                    <div class="quick-actions">
                        <a href="#" onclick="showPage('packs-page')" class="action-btn">
                            <div class="btn btn-primary">Packs</div>
                        </a>
                        <a href="#" onclick="showPage('blooks-page')" class="action-btn">
                            <div class="btn btn-primary">Blooks</div>
                        </a>
                        <a href="#" onclick="showPage('auction-page')" class="action-btn">
                            <div class="btn btn-primary">Auction</div>
                        </a>
                        <a href="#" onclick="showPage('trade-page')" class="action-btn">
                            <div class="btn btn-primary">Trade</div>
                        </a>
                    </div>

                    <h2>Recent Activity</h2>
                    <ul class="activity-list">
                        <li>Purchased Standard Pack - 250 coins</li>
                        <li>Won Frog (Uncommon) from pack</li>
                        <li>Logged in 2 hours ago</li>
                    </ul>
                </div>

                <nav class="bottom-nav">
                    <a href="#" onclick="showPage('stats-page')" class="nav-link">Stats</a>
                    <a href="#" onclick="logout()" class="nav-link">Logout</a>
                </nav>
            </div>
        </div>

        <!-- Packs Page -->
        <div id="packs-page" class="page">
            <div class="dashboard-container">
                <nav class="navbar">
                    <div class="navbar-brand">
                        <a href="#" onclick="showPage('dashboard-page')">
                            <span class="logo-white">WHITE</span><span class="logo-blue">LET</span>
                        </a>
                        <span class="market-title">PACKS</span>
                    </div>
                    <div class="user-info">
                        <span>Welcome, <span id="packs-username">Augustine2025</span></span>
                        <span class="balance">Balance: <span id="packs-balance">5,250</span></span>
                    </div>
                </nav>

                <div class="packs-container">
                    <div class="pack-categories">
                        <button class="pack-category-btn active" data-category="all">All Packs</button>
                        <button class="pack-category-btn" data-category="standard">Standard</button>
                        <button class="pack-category-btn" data-category="premium">Premium</button>
                        <button class="pack-category-btn" data-category="special">Special</button>
                    </div>

                    <div class="packs-grid">
                        <!-- Standard Pack -->
                        <div class="pack-card standard" data-rarity="uncommon">
                            <div class="pack-image-placeholder" style="height: 150px; background-color: #E6F2FF; display: flex; align-items: center; justify-content: center; margin-bottom: 10px;">
                                <span>Standard Pack Image</span>
                            </div>
                            <h3>Standard Pack</h3>
                            <p class="pack-price">250</p>
                            <p class="pack-odds">Guaranteed Uncommon</p>
                            <button class="btn btn-primary buy-pack">Buy</button>
                        </div>

                        <!-- Premium Pack -->
                        <div class="pack-card premium" data-rarity="rare">
                            <div class="pack-image-placeholder" style="height: 150px; background-color: #E6F2FF; display: flex; align-items: center; justify-content: center; margin-bottom: 10px;">
                                <span>Premium Pack Image</span>
                            </div>
                            <h3>Premium Pack</h3>
                            <p class="pack-price">750</p>
                            <p class="pack-odds">Guaranteed Rare</p>
                            <button class="btn btn-primary buy-pack">Buy</button>
                        </div>

                        <!-- Epic Pack -->
                        <div class="pack-card special" data-rarity="epic">
                            <div class="pack-image-placeholder" style="height: 150px; background-color: #E6F2FF; display: flex; align-items: center; justify-content: center; margin-bottom: 10px;">
                                <span>Epic Pack Image</span>
                            </div>
                            <h3>Epic Pack</h3>
                            <p class="pack-price">1,500</p>
                            <p class="pack-odds">Guaranteed Epic</p>
                            <button class="btn btn-primary buy-pack">Buy</button>
                        </div>

                        <!-- Legendary Pack -->
                        <div class="pack-card special" data-rarity="legendary">
                            <div class="pack-image-placeholder" style="height: 150px; background-color: #E6F2FF; display: flex; align-items: center; justify-content: center; margin-bottom: 10px;">
                                <span>Legendary Pack Image</span>
                            </div>
                            <h3>Legendary Pack</h3>
                            <p class="pack-price">3,000</p>
                            <p class="pack-odds">Guaranteed Legendary</p>
                            <button class="btn btn-primary buy-pack">Buy</button>
                        </div>

                        <!-- Chroma Pack -->
                        <div class="pack-card special" data-rarity="chroma">
                            <div class="pack-image-placeholder" style="height: 150px; background-color: #E6F2FF; display: flex; align-items: center; justify-content: center; margin-bottom: 10px;">
                                <span>Chroma Pack Image</span>
                            </div>
                            <h3>Chroma Pack</h3>
                            <p class="pack-price">5,000</p>
                            <p class="pack-odds">1% Chance for Chroma</p>
                            <button class="btn btn-primary buy-pack">Buy</button>
                        </div>

                        <!-- Mystical Pack -->
                        <div class="pack-card special" data-rarity="mystical">
                            <div class="pack-image-placeholder" style="height: 150px; background-color: #E6F2FF; display: flex; align-items: center; justify-content: center; margin-bottom: 10px;">
                                <span>Mystical Pack Image</span>
                            </div>
                            <h3>Mystical Pack</h3>
                            <p class="pack-price">10,000</p>
                            <p class="pack-odds">0.1% Chance for Mystical</p>
                            <button class="btn btn-primary buy-pack">Buy</button>
                        </div>
                    </div>
                </div>

                <nav class="bottom-nav">
                    <a href="#" onclick="showPage('dashboard-page')" class="nav-link">← Back to Dashboard</a>
                    <a href="#" onclick="showPage('blooks-page')" class="nav-link">View Blooks</a>
                    <a href="#" onclick="showPage('auction-page')" class="nav-link">Auction House</a>
                </nav>
            </div>

            <!-- Pack Opening Modal -->
            <div class="modal" id="packModal">
                <div class="modal-content">
                    <span class="close-modal" onclick="closeModal('packModal')">&times;</span>
                    <h2 id="packModalTitle">Opening Standard Pack</h2>
                    <div class="pack-opening-animation">
                        <div class="pack-image">
                            <div class="pack-image-placeholder" style="height: 200px; background-color: #E6F2FF; display: flex; align-items: center; justify-content: center; margin-bottom: 10px;">
                                <span>Pack Image</span>
                            </div>
                        </div>
                        <button class="btn btn-primary" id="openPackBtn">Open Pack</button>
                    </div>
                    <div class="pack-results" id="packResults">
                        <!-- Results will be shown here -->
                    </div>
                </div>
            </div>
        </div>

        <!-- Blooks Page -->
        <div id="blooks-page" class="page">
            <div class="dashboard-container">
                <nav class="navbar">
                    <div class="navbar-brand">
                        <a href="#" onclick="showPage('dashboard-page')">
                            <span class="logo-white">WHITE</span><span class="logo-blue">LET</span>
                        </a>
                        <span class="market-title">MY BLOOKS</span>
                    </div>
                    <div class="user-info">
                        <span>Welcome, <span id="blooks-username">Augustine2025</span></span>
                        <span class="balance">Balance: <span id="blooks-balance">5,250</span></span>
                    </div>
                </nav>

                <div class="blooks-container">
                    <div class="blooks-filters">
                        <select id="rarityFilter">
                            <option value="all">All Rarities</option>
                            <option value="uncommon">Uncommon</option>
                            <option value="rare">Rare</option>
                            <option value="epic">Epic</option>
                            <option value="legendary">Legendary</option>
                            <option value="chroma">Chroma</option>
                            <option value="mystical">Mystical</option>
                        </select>
                        <input type="text" id="blookSearch" placeholder="Search blooks...">
                    </div>

                    <div class="blooks-grid" id="blooksGrid">
                        <!-- Blooks will be loaded here -->
                        <div class="blook-card uncommon">
                            <div class="blook-image-placeholder" style="height: 100px; background-color: #E6F2FF; display: flex; align-items: center; justify-content: center; margin-bottom: 10px;">
                                <span>Frog Image</span>
                            </div>
                            <h3>Frog</h3>
                            <p class="blook-rarity">Uncommon</p>
                            <div class="blook-actions">
                                <button class="btn btn-small sell-btn">Sell</button>
                                <button class="btn btn-small auction-btn">Auction</button>
                            </div>
                        </div>

                        <div class="blook-card rare">
                            <div class="blook-image-placeholder" style="height: 100px; background-color: #E6F2FF; display: flex; align-items: center; justify-content: center; margin-bottom: 10px;">
                                <span>Lion Image</span>
                            </div>
                            <h3>Lion</h3>
                            <p class="blook-rarity">Rare</p>
                            <div class="blook-actions">
                                <button class="btn btn-small sell-btn">Sell</button>
                                <button class="btn btn-small auction-btn">Auction</button>
                            </div>
                        </div>

                        <div class="blook-card epic">
                            <div class="blook-image-placeholder" style="height: 100px; background-color: #E6F2FF; display: flex; align-items: center; justify-content: center; margin-bottom: 10px;">
                                <span>Dragon Image</span>
                            </div>
                            <h3>Dragon</h3>
                            <p class="blook-rarity">Epic</p>
                            <div class="blook-actions">
                                <button class="btn btn-small sell-btn">Sell</button>
                                <button class="btn btn-small auction-btn">Auction</button>
                            </div>
                        </div>
                    </div>
                </div>

                <nav class="bottom-nav">
                    <a href="#" onclick="showPage('dashboard-page')" class="nav-link">← Back to Dashboard</a>
                    <a href="#" onclick="showPage('packs-page')" class="nav-link">Buy Packs</a>
                    <a href="#" onclick="showPage('auction-page')" class="nav-link">Auction House</a>
                    <a href="#" onclick="showPage('trade-page')" class="nav-link">Trade Center</a>
                </nav>
            </div>

            <!-- Sell Blook Modal -->
            <div class="modal" id="sellModal">
                <div class="modal-content">
                    <span class="close-modal" onclick="closeModal('sellModal')">&times;</span>
                    <h2 id="sellModalTitle">Sell <span id="blookName">Frog</span></h2>
                    <div class="sell-form">
                        <div class="form-group">
                            <label for="sellPrice">Price:</label>
                            <input type="number" id="sellPrice" min="1" value="100">
                        </div>
                        <button class="btn btn-primary" id="confirmSell">Sell Blook</button>
                    </div>
                </div>
            </div>

            <!-- Auction Blook Modal -->
            <div class="modal" id="auctionModal">
                <div class="modal-content">
                    <span class="close-modal" onclick="closeModal('auctionModal')">&times;</span>
                    <h2 id="auctionModalTitle">Auction <span id="auctionBlookName">Lion</span></h2>
                    <div class="auction-form">
